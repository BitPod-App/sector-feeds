# Copy to `.bitpod_runtime.env` for local runtime overrides.
# This file is safe to commit; keep secrets only in `.bitpod_runtime.env`.

# OpenAI runtime settings (optional, depends on your local setup).
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini-transcribe

# Provenance tuple (two-axis model).
# Valid origin actors: CJ | GPT | CODEX | TAYLOR | HUMAN_TEAM | OTHER
BITPOD_ORIGIN_ACTOR=OTHER

# Valid authority states: PROPOSAL | CJ_ENDORSED | TEAM_ENDORSED | CJ_OVERRIDE
BITPOD_AUTHORITY_STATE=PROPOSAL

# Spec lock envelope.
BITPOD_EXPANSION_GATE=BLOCKED
BITPOD_SPEC_LOCK_ORIGINAL_ASK=
# Comma-separated lists:
BITPOD_SPEC_LOCK_SUCCESS_CRITERIA=
BITPOD_SPEC_LOCK_OUT_OF_SCOPE=
BITPOD_BASELINE_REFS=

# Soft override guard (visibility only, non-blocking).
# Set BITPOD_OVERRIDE_CONFLICT=1 when CJ_OVERRIDE conflicts with prior endorsed baseline.
BITPOD_OVERRIDE_CONFLICT=0
BITPOD_OVERRIDE_CONFLICT_NOTE=
BITPOD_OVERRIDE_IMPACTED_DECISION=
BITPOD_OVERRIDE_BROADCAST_NOTE=
