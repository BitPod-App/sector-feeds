# Bitpod runtime budget defaults (auto-loaded by scripts/run_show_weekly.sh)
# Policy: warn-but-continue until task is done, fail-stop on hard cap.

# Enable GPT report generation in weekly flow.
WEEKLY_GPT_REPORT=1

# Cost meter filtering source.
COST_SOURCE=bitpod.gpt_report_from_transcript

# Cost window controls.
COST_WINDOW_HOURS=24

# Estimated token caps.
COST_RUN_WARN=2500
COST_RUN_FAIL=6000
COST_DAILY_WARN=12000
COST_DAILY_FAIL=24000

# Keep warnings non-blocking; fail cap still blocks.
COST_WARN_EXIT_0=1
